# ─── Django Core ─────────────────────────────────────────────
SECRET_KEY=django-insecure-replace-this-with-50-random-chars
DEBUG=True
ALLOWED_HOSTS=localhost,127.0.0.1

# ─── Database ─────────────────────────────────────────────────
# SQLite (development):
DATABASE_URL=sqlite:///db.sqlite3
# PostgreSQL (production — from Railway/Render):
# DATABASE_URL=postgresql://user:password@host:5432/dbname

# ─── CORS ─────────────────────────────────────────────────────
CORS_ALLOWED_ORIGINS=http://localhost:5173,http://localhost:3000

# ─── Stripe ───────────────────────────────────────────────────
STRIPE_SECRET_KEY=sk_test_your_stripe_secret_key_here
STRIPE_PUBLISHABLE_KEY=pk_test_your_stripe_publishable_key_here
STRIPE_WEBHOOK_SECRET=whsec_your_webhook_secret_here

# ─── Redis / Celery ───────────────────────────────────────────
REDIS_URL=redis://localhost:6379/0

# ─── Email (optional — console backend for dev) ───────────────
EMAIL_BACKEND=django.core.mail.backends.console.EmailBackend
# EMAIL_BACKEND=django.core.mail.backends.smtp.EmailBackend
EMAIL_HOST=smtp.gmail.com
EMAIL_PORT=587
EMAIL_HOST_USER=your-gmail@gmail.com
EMAIL_HOST_PASSWORD=your-app-password
DEFAULT_FROM_EMAIL=ShopKart <noreply@shopkart.com>

# ─── S3 / Cloudflare R2 (optional, false = local storage) ─────
USE_S3=False
# AWS_ACCESS_KEY_ID=your_key
# AWS_SECRET_ACCESS_KEY=your_secret
# AWS_STORAGE_BUCKET_NAME=shopkart-media
# AWS_S3_REGION_NAME=us-east-1
